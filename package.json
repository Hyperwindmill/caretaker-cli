{
  "name": "caretaker-cli-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Caretaker — a multi-surface AI agent harness: CLI/TUI, local web GUI, Electron desktop app, and VSCode sidebar.",
  "license": "SEE LICENSE IN LICENSE",
  "author": "Hyperwindmill <hyperwindmill@gmail.com>",
  "homepage": "https://github.com/Hyperwindmill/caretaker-cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hyperwindmill/caretaker-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Hyperwindmill/caretaker-cli/issues"
  },
  "scripts": {
    "dev": "pnpm -F @hyperwindmill/caretaker-cli dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check",
    "link:global": "pnpm -F @hyperwindmill/caretaker-cli link:global",
    "desktop:build": "pnpm -F caretaker-desktop build",
    "desktop:dev": "pnpm build && pnpm -F caretaker-desktop dev",
    "desktop:pack": "pnpm build && pnpm -F caretaker-desktop exec electron-builder --dir",
    "desktop:dist": "pnpm build && pnpm -F caretaker-desktop exec electron-builder",
    "vscode:package": "pnpm build && pnpm -F caretaker-vscode package",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "husky": "^9.1.7"
  },
  "pnpm": {
    "overrides": {
      "undici": ">=7.28.0",
      "form-data": ">=4.0.6",
      "tmp": ">=0.2.6",
      "lodash-es": ">=4.18.0",
      "markdown-it": ">=14.2.0",
      "linkify-it": "^5.0.1",
      "qs": ">=6.15.2",
      "js-yaml": ">=4.2.0",
      "read-yaml-file>js-yaml": "^3.14.1",
      "esbuild": ">=0.28.1"
    }
  }
}
