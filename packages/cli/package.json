{
  "name": "caretaker-cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Caretaker — in-process agent harness, TUI, file-based state.",
  "bin": {
    "caretaker-cli": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./harness": {
      "types": "./dist/harness/index.d.ts",
      "default": "./dist/harness/index.js"
    },
    "./store": {
      "types": "./dist/store/json.d.ts",
      "default": "./dist/store/json.js"
    },
    "./session": {
      "types": "./dist/session/index.d.ts",
      "default": "./dist/session/index.js"
    },
    "./plugins": {
      "types": "./dist/plugins/source_manager.d.ts",
      "default": "./dist/plugins/source_manager.js"
    },
    "./mcp": {
      "types": "./dist/mcp/server_manager.d.ts",
      "default": "./dist/mcp/server_manager.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "link:global": "pnpm run build && pnpm link --global",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@morphql/store": "^0.1.45",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "hono": "^4.12.22",
    "ink": "^7.0.2",
    "ink-big-text": "^2.0.0",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "isomorphic-git": "^1.37.6",
    "react": "^19.2.6",
    "turndown": "^7.2.4",
    "webview-ui": "workspace:*",
    "ws": "^8.21.0",
    "yaml": "^2.8.4"
  }
}
