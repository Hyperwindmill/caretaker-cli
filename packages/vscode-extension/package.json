{
  "name": "caretaker-vscode",
  "displayName": "Caretaker",
  "description": "Caretaker agent harness — chat sidebar for VSCode.",
  "version": "0.10.1",
  "private": true,
  "publisher": "Hyperwindmill",
  "author": "Hyperwindmill <hyperwindmill@gmail.com>",
  "license": "SEE LICENSE IN LICENSE",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hyperwindmill/caretaker-cli.git",
    "directory": "packages/vscode-extension"
  },
  "engines": {
    "vscode": "^1.95.0",
    "node": ">=20"
  },
  "main": "./dist/extension.js",
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "caretaker",
          "title": "Caretaker",
          "icon": "activity-bar-icon.png"
        }
      ]
    },
    "views": {
      "caretaker": [
        {
          "type": "webview",
          "id": "caretaker.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "caretaker.openChat",
        "title": "Caretaker: Open Chat",
        "category": "Caretaker"
      }
    ],
    "configuration": {
      "title": "Caretaker",
      "properties": {
        "caretaker.home": {
          "type": "string",
          "default": "",
          "description": "Override the CARETAKER_HOME directory. The CARETAKER_HOME env var still takes precedence. Leave empty for the default (~/.caretaker)."
        },
        "caretaker.defaultAgent": {
          "type": "string",
          "default": "",
          "description": "Name of the agent selected on activation. Empty = first available."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "tsc --noEmit false --declaration false && node --test \"dist/**/*.test.js\"",
    "vscode:prepublish": "pnpm -w run build",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "caretaker-cli": "workspace:*",
    "webview-ui": "workspace:*",
    "marked": "^15.0.12",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.27.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}