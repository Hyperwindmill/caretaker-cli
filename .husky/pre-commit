#!/bin/sh

# Skip the check on the main branch (main/master), in detached HEAD, or during a release.
CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)
if [ "$CURRENT_BRANCH" = "main" ] || [ "$CURRENT_BRANCH" = "master" ] || [ -z "$CURRENT_BRANCH" ]; then
    exit 0
fi

# Check whether any changeset files (.changeset/*.md) are staged in this commit.
# Ignore the changesets README.md.
CHANGESET_STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E "^\.changeset/[a-zA-Z0-9_-]+\.md$" | grep -v "README.md")

if [ -z "$CHANGESET_STAGED" ]; then
    echo -e "\n\033[31m[ERROR] No changeset staged!\033[0m"
    echo -e "Since you are on the feature branch '\033[36m$CURRENT_BRANCH\033[0m', you must add a changeset before committing."
    echo -e "Please create one by running:"
    echo -e "  \033[33mpnpm run changeset\033[0m"
    echo -e "Then stage it before committing again.\n"
    exit 1
fi
